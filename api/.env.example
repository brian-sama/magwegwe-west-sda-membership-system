APP_NAME="Magwegwe West SDA Membership API"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=Africa/Harare

# CORS: comma-separated list, or *
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_target_database
DB_USERNAME=your_target_db_user
DB_PASSWORD=your_target_db_password
DB_CHARSET=utf8mb4

# Optional source DB for migration. If omitted, target DB is used.
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=3306
SOURCE_DB_DATABASE=your_source_database
SOURCE_DB_USERNAME=your_source_db_user
SOURCE_DB_PASSWORD=your_source_db_password
SOURCE_DB_CHARSET=utf8mb4

JWT_SECRET=change_this_to_a_long_random_secret
JWT_TTL_SECONDS=28800

AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash