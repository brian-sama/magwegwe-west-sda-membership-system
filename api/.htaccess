RewriteEngine On

# Handle preflight OPTIONS requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Route: /api/auth/login -> auth/login.php
RewriteRule ^auth/login$ auth/login.php [L,QSA]

# Route: /api/members/{id} -> members/index.php
RewriteRule ^members/(.+)$ members/index.php [L,QSA]
RewriteRule ^members$ members/index.php [L,QSA]

# Route: /api/youth/{id} -> youth/index.php
RewriteRule ^youth/(.+)$ youth/index.php [L,QSA]
RewriteRule ^youth$ youth/index.php [L,QSA]

# Route: /api/society/{id} -> society/index.php
RewriteRule ^society/(.+)$ society/index.php [L,QSA]
RewriteRule ^society$ society/index.php [L,QSA]

# Route: /api/users/{id} -> users/index.php
RewriteRule ^users/(.+)$ users/index.php [L,QSA]
RewriteRule ^users$ users/index.php [L,QSA]

# Route: /api/logs -> logs/index.php
RewriteRule ^logs/(.+)$ logs/index.php [L,QSA]
RewriteRule ^logs$ logs/index.php [L,QSA]
